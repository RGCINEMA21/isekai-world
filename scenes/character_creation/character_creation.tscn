[gd_scene load_steps=3 format=3 uid="uid://char001"]

[ext_resource type="Script" path="res://scripts/character_creation/character_creation.gd" id="1"]

[node name="CharacterCreation" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.1, 0.12, 0.2, 1)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -220.0
offset_right = 200.0
offset_bottom = 220.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Buat Karakter"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32

[node name="NameLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Nama Karakter:"
theme_override_font_sizes/font_size = 18

[node name="NameInput" type="LineEdit" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Masukkan nama..."
max_length = 15
size_flags_horizontal = 3

[node name="GenderLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Pilih Gender:"
theme_override_font_sizes/font_size = 18

[node name="GenderHBox" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 20

[node name="MaleButton" type="CheckButton" parent="VBox/GenderHBox"]
unique_name_in_owner = true
layout_mode = 2
button_pressed = true
text = "Laki-laki"
theme_override_font_sizes/font_size = 16

[node name="FemaleButton" type="CheckButton" parent="VBox/GenderHBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Perempuan"
theme_override_font_sizes/font_size = 16

[node name="PreviewLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Karakter: Laki-laki"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.8, 0.8, 0.8, 1)

[node name="StartButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(250, 50)
text = "Mulai Petualangan!"
theme_override_font_sizes/font_size = 20

[node name="BackButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(250, 50)
text = "Kembali"
theme_override_font_sizes/font_size = 18

[connection signal="text_changed" from="VBox/NameInput" to="." method="_on_name_input_text_changed"]
[connection signal="toggled" from="VBox/GenderHBox/MaleButton" to="." method="_on_male_button_pressed"]
[connection signal="toggled" from="VBox/GenderHBox/FemaleButton" to="." method="_on_female_button_pressed"]
[connection signal="pressed" from="VBox/StartButton" to="." method="_on_start_button_pressed"]
[connection signal="pressed" from="VBox/BackButton" to="." method="_on_back_button_pressed"]
